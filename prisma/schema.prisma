generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  preferences Json?    // Array of strings or object
  onboarding  Json?    // Store: { goal, sensitivity, time, transport }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  name        String
  type        String   // music, sport, food, art, tech
  lat         Float
  lng         Float
  place       String
  address     String
  date        String
  time        String
  price       String
  crowdLevel  Int      // 0-100
  attending   String
  description String
  tickets     String[] // URLs or names
  source      String?
  link        String?
  createdAt   DateTime @default(now())
}

model Crime {
  id          String   @id @default(cuid())
  type        String   // Theft, Accident, Robbery, etc.
  severity    Int      // 1-5
  lat         Float
  lng         Float
  description String
  timestamp   DateTime @default(now())
}
